{
    "name": "@notchclip/app",
    "private": true,
    "scripts": {
        "project:generate": "xcodegen generate --spec project.yml",
        "build": "bun run project:generate && xcodebuild -project NotchClip.xcodeproj -scheme NotchClip -configuration Debug -destination 'platform=macOS' build",
        "install:app": "./scripts/install.sh",
        "icons": "./scripts/generate_icons.sh",
        "dmg": "./scripts/make_dmg.sh",
        "typecheck": "swiftc -typecheck -swift-version 6 -parse-as-library $(find NotchClip -name '*.swift' | sort)"
    }
}
